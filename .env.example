# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Web Search
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WEB_SEARCH_PROVIDER=tavily

# URL Ingestion
URL_INGESTION_ENABLED=true
URL_SCRAPE_TIMEOUT=10
URL_MIN_CONTENT_WORDS=100
URL_MAX_CONTENT_WORDS=50000

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_DAILY_MESSAGE_LIMIT=50
WEBHOOK_PORT=8000
WHATSAPP_ENABLED=true

# Scheduler / Proactive Reminders
SCHEDULER_ENABLED=true
MORNING_BRIEFING_TIME=08:00
HABIT_NUDGE_TIME=21:00
YOUR_WHATSAPP_NUMBER=whatsapp:+14155551234

# Habit Tracker
HABIT_DEFAULT_REMINDER_TIME=21:00
